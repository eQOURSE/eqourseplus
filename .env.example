# ---- copy to .env (never commit .env) ----
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
# Mongo (Atlas connection string, per environment)
MONGODB_URI=
# Auth
JWT_SECRET=
OTP_EMAIL_FROM=
# Redis (Upstash)
REDIS_URL=
# Storage (Cloudflare R2 - S3 compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_KYC=eqplus-kyc-docs
R2_BUCKET_ASSETS=eqplus-project-assets
# KYC provider (sandbox first) — via KYCAdapter
KYC_PROVIDER=sandbox   # sandbox|idfy|sumsub
IDFY_API_KEY=
SUMSUB_APP_TOKEN=
# E-sign — via ESignAdapter
ESIGN_PROVIDER=sandbox # sandbox|digio|dropboxsign
# Payouts — via PayoutAdapter
PAYOUT_PROVIDER=sandbox # sandbox|razorpayx|wise
# Email
RESEND_API_KEY=
# LLM (AI features)
ANTHROPIC_API_KEY=
# Monitoring
SENTRY_DSN=
